# Copy this file to .env and fill in real values. .env is gitignored - never commit real credentials.

# Gmail: use an App Password (Google Account > Security > 2-Step Verification > App Passwords),
# not your normal Gmail password.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD=your16charapppassword
MAIL_FROM=youraddress@gmail.com

# Admin recipient for the monthly report email
ADMIN_EMAIL=admin@trekking.com

# Google Chat: Space > Apps & integrations > Manage webhooks > Add webhook, paste the URL below.
# Leave blank to skip Chat notifications (reminders fall back to console-print).
GCHAT_WEBHOOK_URL=
